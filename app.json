{
  "expo": {
    "name": "攀岩夥伴",
    "slug": "climber-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "climber",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.climberapp.v1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.climberapp.v1"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-sqlite",
        {
          "enableFTS": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
